DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-long-random-secret
DJANGO_ALLOWED_HOSTS=insidehistory.ru,www.insidehistory.ru
# Опционально: явный список Origin для CSRF (иначе в проде берётся https:// + каждый хост из ALLOWED_HOSTS)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://insidehistory.ru,https://www.insidehistory.ru
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_USE_X_FORWARDED_PROTO=1
QUIZ_SCENE_COUNT=5

# AI генерация сцен (scripts/generate_scenes_ai.py)
# OPENAI_API_KEY=<your_openai_api_key>
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_IMAGE_MODEL=gpt-image-2
# GEMINI_API_KEY=<your_gemini_api_key>
# GEMINI_TEXT_MODEL=gemini-2.0-flash

# PostgreSQL (если задан POSTGRES_HOST — SQLite не используется)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=insidehistory
# POSTGRES_USER=insidehistory
# POSTGRES_PASSWORD=strong-password
# POSTGRES_CONN_MAX_AGE=60
# POSTGRES_CONNECT_TIMEOUT=10
