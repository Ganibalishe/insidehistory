DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-long-random-secret
DJANGO_ALLOWED_HOSTS=insidehistory.ru,www.insidehistory.ru
# Опционально: явный список Origin для CSRF (иначе в проде берётся https:// + каждый хост из ALLOWED_HOSTS)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://insidehistory.ru,https://www.insidehistory.ru
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_USE_X_FORWARDED_PROTO=1
QUIZ_SCENE_COUNT=5
QUIZ_QUESTIONS_PER_SCENE=3

# Gunicorn (читается gunicorn.conf.py; после смены — systemctl restart insidehistory)
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=1
# GUNICORN_TIMEOUT=60

# AI генерация сцен (scripts/generate_scenes_ai.py)
# OPENAI_API_KEY=<your_openai_api_key>
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_SIZE=3840x1920
# OPENAI_IMAGE_QUALITY=high
# GEMINI_API_KEY=<your_gemini_api_key>
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# Логи JSON агентов на диск: переменная не читается скриптом; используйте флаг:
#   --agent-responses-dir ./var/agent_logs
# Печать запроса/ответа агентов в stderr: --echo-agent-json
#   [--echo-agent-json-max-chars 0] [--echo-agent-request-max-user-chars 0]

# PostgreSQL (если задан POSTGRES_HOST — SQLite не используется)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=insidehistory
# POSTGRES_USER=insidehistory
# POSTGRES_PASSWORD=strong-password
# POSTGRES_CONN_MAX_AGE=60
# POSTGRES_CONNECT_TIMEOUT=10
